myont:departmentDisplays a owl:ObjectProperty ;
    rdfs:label "department displays" ;
    rdfs:comment "Relates a museum department to the human-made objects it displays." ;
    rdfs:domain myont:Department ;
    rdfs:range crm:E22_Human_Made_Object ;
    owl:inverseOf myont:displayedInDepartment .

myont:displayedInDepartment a owl:ObjectProperty ;
    rdfs:label "displayed in department" ;
    rdfs:comment "Relates a human-made object to the museum department where it is displayed." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Department .

myont:displays a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "displays" ;
    rdfs:comment "Relates a museum to the human-made objects it displays." ;
    rdfs:domain myont:Museum ;
    rdfs:range crm:E22_Human_Made_Object .

myont:hasCulture a owl:DatatypeProperty ;
    rdfs:label "culture" ;
    rdfs:comment "A textual value describing the cultural origin or association of a human-made object." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:isDepartmentOf a owl:ObjectProperty ;
    rdfs:label "is department of" ;
    rdfs:comment "Relates a department to the museum it belongs to." ;
    rdfs:domain myont:Department ;
    rdfs:range myont:Museum .

myont:isThemeOf a owl:ObjectProperty ;
    rdfs:label "is theme of" ;
    rdfs:comment "Relates a theme to the human-made objects that are associated with it." ;
    rdfs:domain myont:Theme ;
    rdfs:range crm:E22_Human_Made_Object .

myont:mediumDescription a owl:DatatypeProperty ;
    rdfs:label "Labeled Medium" ;
    rdfs:comment "A textual description of the material or medium used to create a human-made object." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

schema:Museum a owl:Class ;
    rdfs:label "Museum" ;
    rdfs:comment "An institution that collects, preserves, studies, and displays objects of artistic, cultural, or historical significance." .

schema:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:comment "A work of visual art created by applying paint to a surface such as canvas, wood, or paper." .

schema:Sculpture a owl:Class ;
    rdfs:label "Sculpture" ;
    rdfs:comment "Any sculpture that has a known artist is included here." .

schema:creator a owl:ObjectProperty .

schema:name a owl:DatatypeProperty ;
    rdfs:comment "The name or title of an entity, represented as a string." ;
    rdfs:range xsd:string .

crm:E39_Actor a owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment "An entity capable of performing actions or participating in events, including individuals or groups." .

