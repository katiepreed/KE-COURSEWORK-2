@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix myont: <https://ontologeez/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

crm:P102_has_title a owl:DatatypeProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:name .

myont:AnimalTheme a owl:Class ;
    rdfs:label "Animal theme" ;
    rdfs:subClassOf myont:Theme .

myont:Blue_Horses a myont:Painting ;
    myont:createdBy myont:Franz_Marc ;
    schema:name "Blue Horses" .

myont:Ceramic a owl:Class ;
    rdfs:label "Ceramic" ;
    rdfs:subClassOf myont:Artifact .

myont:City a owl:Class ;
    rdfs:label "City" ;
    rdfs:subClassOf crm:E53_Place .

myont:Country a owl:Class ;
    rdfs:label "Country" ;
    rdfs:subClassOf crm:E53_Place .

myont:Czanne a myont:Painting ;
    myont:hasPeriod "beautiful aesthetic" ;
    schema:name "Cézanne" .

myont:Dal a myont:Painting ;
    myont:hasPeriod "Surrealists" ;
    schema:name "Dalí" .

myont:De_Chirico a myont:Painting ;
    myont:hasPeriod "Surrealists" ;
    myont:hasTheme myont:enigmatic_style ;
    schema:name "De Chirico" .

myont:Death_of_Sardanapalus a myont:Painting ;
    myont:createdBy myont:Eugene_Delacroix ;
    schema:name "Death of Sardanapalus" .

myont:Delacroix a myont:Painting ;
    myont:hasTheme myont:violence ;
    schema:name "Delacroix" .

myont:El_Greco a myont:Painting ;
    myont:hasTheme myont:divine ;
    schema:name "El Greco" .

myont:Figurine a owl:Class ;
    rdfs:label "Figurine" ;
    rdfs:subClassOf myont:Artifact .

myont:Fuseli a myont:Painting ;
    myont:hasTheme myont:surrealism ;
    schema:name "Fuseli" .

myont:Gauguin a myont:Painting ;
    myont:hasTheme myont:landscape ;
    schema:name "Gauguin" .

myont:Giotto a myont:Painting ;
    myont:hasPeriod "The Renaissance" ;
    myont:hasTheme myont:fresco ;
    schema:name "Giotto" .

myont:Hopper a myont:Painting ;
    myont:hasTheme myont:realism ;
    schema:name "Hopper" .

myont:Improvisation a myont:Painting ;
    myont:createdBy myont:Kandinsky ;
    schema:name "Improvisation" .

myont:Jewellery a owl:Class ;
    rdfs:label "Jewellery" ;
    rdfs:subClassOf myont:Artifact .

myont:MoMA a myont:Painting ;
    myont:displayedBy myont:New_York ;
    schema:name "MoMA" .

myont:Monet_scene a myont:Painting ;
    myont:hasTheme myont:winter_day ;
    schema:name "Monet scene" .

myont:Montagne_SaintVictoire a myont:Painting ;
    myont:createdBy myont:Paul_Czanne ;
    schema:name "Montagne Saint-Victoire" .

myont:MythologicalTheme a owl:Class ;
    rdfs:label "Mythological theme" ;
    rdfs:subClassOf myont:Theme .

myont:Narcissus a myont:Painting ;
    myont:hasTheme myont:stony_figure ;
    schema:name "Narcissus" .

myont:NatureTheme a owl:Class ;
    rdfs:label "Nature theme" ;
    rdfs:subClassOf myont:Theme .

myont:Newton a myont:Painting ;
    myont:createdBy myont:Blake ;
    schema:name "Newton" .

myont:Picasso a myont:Painting ;
    myont:hasPeriod "naturalism" ;
    schema:name "Picasso" .

myont:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:subClassOf crm:E53_Place .

myont:ReligiousTheme a owl:Class ;
    rdfs:label "Religious theme" ;
    rdfs:subClassOf myont:Theme .

myont:Scroll a owl:Class ;
    rdfs:label "Scroll" ;
    rdfs:subClassOf myont:Artifact .

myont:Sculpture a owl:Class ;
    rdfs:label "Sculpture" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:equivalentClass schema:Sculpture .

myont:Separation_by_Edvard_Munch a myont:Painting ;
    schema:dateCreated "1896" ;
    schema:name "Separation by Edvard Munch" .

myont:Snow_Storm__SteamBoat_off_a_Harbour_Mouth a myont:Painting ;
    schema:dateCreated "1842" ;
    schema:name "Snow Storm – Steam-Boat off a Harbour Mouth" .

myont:Statue a owl:Class ;
    rdfs:label "Statue" ;
    rdfs:subClassOf myont:Artifact .

myont:Tahitian_Landscape a myont:Painting ;
    myont:createdBy myont:Paul_Gauguin ;
    schema:name "Tahitian Landscape" .

myont:The_Hunters_in_the_Snow a myont:Painting ;
    myont:createdBy myont:Pieter_Bruegel ;
    schema:name "The Hunters in the Snow" .

myont:The_Lane_of_Poplars a myont:Painting ;
    myont:createdBy myont:Alfred_Sisley ;
    schema:name "The Lane of Poplars" .

myont:The_Last_Supper a myont:Painting ;
    myont:createdBy myont:Tintoretto ;
    schema:name "The Last Supper" .

myont:Van_Gogh a myont:Painting ;
    myont:hasPeriod "expressionism" ;
    schema:name "Van Gogh" .

myont:Vase a owl:Class ;
    rdfs:label "Vase" ;
    rdfs:subClassOf myont:Artifact .

myont:Velazquez a myont:Painting ;
    myont:hasTheme myont:contrast ;
    schema:name "Velazquez" .

myont:bornOn a owl:DatatypeProperty ;
    rdfs:label "born in" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:gYear .

myont:createdBy a owl:ObjectProperty ;
    rdfs:label "created by artist" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Artist ;
    rdfs:subPropertyOf crm:P108i_was_produced_by,
        schema:creator ;
    owl:inverseOf myont:hasCreated .

myont:diedOn a owl:DatatypeProperty ;
    rdfs:label "died in" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:gYear .

myont:discoveredIn a owl:ObjectProperty ;
    rdfs:label "discovered in" ;
    rdfs:domain myont:Artifact ;
    rdfs:range crm:E53_Place .

myont:displayedBy a owl:ObjectProperty ;
    rdfs:label "displayed by museum" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Museum ;
    owl:inverseOf myont:displays .

myont:displayedInDepartment a owl:ObjectProperty ;
    rdfs:label "displayed in department" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Department .

myont:endDate a owl:DatatypeProperty ;
    rdfs:label "artwork finished in" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:gYear .

myont:famous_painting a myont:Painting ;
    myont:createdBy myont:Magritte,
        myont:Marc ;
    schema:name "famous painting" .

myont:famous_rendering a myont:Painting ;
    myont:createdBy myont:Leonardo_da_Vinci ;
    schema:name "famous rendering" .

myont:hasCulture a owl:DatatypeProperty ;
    rdfs:label "culture" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:hasDepartment a owl:ObjectProperty ;
    rdfs:label "has department" ;
    rdfs:domain myont:Museum ;
    rdfs:range myont:Department ;
    owl:inverseOf myont:isDepartmentOf .

myont:hasDepartmentId a owl:DatatypeProperty ;
    rdfs:label "department id" ;
    rdfs:domain myont:Department ;
    rdfs:range xsd:integer .

myont:hasNationality a owl:DatatypeProperty ;
    rdfs:label "nationality" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:string .

myont:hasObjectId a owl:DatatypeProperty ;
    rdfs:label "object id" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:integer .

myont:hasPeriod a owl:DatatypeProperty ;
    rdfs:label "period" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:hasTheme a owl:ObjectProperty ;
    rdfs:label "Theme" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Theme ;
    owl:inverseOf myont:isThemeOf .

myont:mediumDescription a owl:DatatypeProperty ;
    rdfs:label "Labeled Medium" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:startDate a owl:DatatypeProperty ;
    rdfs:label "started in" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:gYear .

myont:village_in_the_cold_wilderness a myont:Painting ;
    myont:createdBy myont:Bruegel ;
    schema:name "village in the cold wilderness" .

schema:Person a owl:Class ;
    rdfs:label "Person" ;
    owl:equivalentClass crm:E21_Person .

schema:dateCreated a owl:DatatypeProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

schema:displayLocation a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place ;
    owl:equivalentProperty crm:P55_has_current_location .

schema:locationCreated a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

crm:E39_Actor a owl:Class ;
    rdfs:label "Actor" .

crm:P108i_was_produced_by a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Artist .

crm:P55_has_current_location a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

myont:Alfred_Sisley a myont:Artist ;
    schema:name "Alfred Sisley" .

myont:Bacchus a myont:Painting ;
    myont:hasTheme myont:Bacchus ;
    schema:name "Bacchus" .

myont:Blake a myont:Artist ;
    schema:name "Blake" .

myont:Bruegel a myont:Artist ;
    schema:name "Bruegel" .

myont:Eugene_Delacroix a myont:Artist ;
    schema:name "Eugene Delacroix" .

myont:Franz_Marc a myont:Artist ;
    schema:name "Franz Marc" .

myont:Kandinsky a myont:Artist ;
    schema:name "Kandinsky" .

myont:Leonardo_da_Vinci a myont:Artist ;
    schema:name "Leonardo da Vinci" .

myont:Magritte a myont:Artist ;
    myont:hasTheme myont:enigma,
        myont:humorous ;
    schema:name "Magritte" .

myont:Marc a myont:Artist ;
    schema:name "Marc" .

myont:New_York a myont:Museum ;
    schema:name "New York" .

myont:Paul_Czanne a myont:Artist ;
    schema:name "Paul Cézanne" .

myont:Paul_Gauguin a myont:Artist ;
    schema:name "Paul Gauguin" .

myont:Pieter_Bruegel a myont:Artist ;
    schema:name "Pieter Bruegel" .

myont:Sisley a myont:Painting ;
    myont:hasTheme myont:Sisley ;
    schema:name "Sisley" .

myont:Tintoretto a myont:Artist ;
    schema:name "Tintoretto" .

myont:contrast a myont:Theme ;
    schema:name "contrast" .

myont:displays a owl:ObjectProperty ;
    rdfs:label "displays" ;
    rdfs:domain myont:Museum ;
    rdfs:range crm:E22_Human_Made_Object .

myont:divine a myont:Theme ;
    schema:name "divine" .

myont:enigma a myont:Theme ;
    schema:name "enigma" .

myont:enigmatic_style a myont:Theme ;
    schema:name "enigmatic style" .

myont:fresco a myont:Theme ;
    schema:name "fresco" .

myont:hasCreated a owl:ObjectProperty ;
    rdfs:label "has created" ;
    rdfs:domain myont:Artist ;
    rdfs:range crm:E22_Human_Made_Object .

myont:humorous a myont:Theme ;
    schema:name "humorous" .

myont:isDepartmentOf a owl:ObjectProperty ;
    rdfs:label "is department of" ;
    rdfs:domain myont:Department ;
    rdfs:range myont:Museum .

myont:isThemeOf a owl:ObjectProperty ;
    rdfs:label "is theme of" ;
    rdfs:domain myont:Theme ;
    rdfs:range crm:E22_Human_Made_Object .

myont:landscape a myont:Theme ;
    schema:name "landscape" .

myont:realism a myont:Theme ;
    schema:name "realism" .

myont:stony_figure a myont:Theme ;
    schema:name "stony figure" .

myont:surrealism a myont:Theme ;
    schema:name "surrealism" .

myont:violence a myont:Theme ;
    schema:name "violence" .

myont:winter_day a myont:Theme ;
    schema:name "winter day" .

schema:Museum a owl:Class ;
    rdfs:label "Museum" .

schema:Painting a owl:Class ;
    rdfs:label "Painting" .

schema:Sculpture a owl:Class ;
    rdfs:label "Sculpture" .

schema:creator a owl:ObjectProperty .

schema:name a owl:DatatypeProperty ;
    rdfs:range xsd:string .

myont:Department a owl:Class ;
    rdfs:label "Department" .

crm:E21_Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf crm:E39_Actor .

myont:Museum a owl:Class ;
    rdfs:label "Museum" ;
    owl:equivalentClass schema:Museum .

crm:E53_Place a owl:Class ;
    rdfs:label "Place" .

myont:Artifact a owl:Class ;
    rdfs:label "Artifact" ;
    rdfs:subClassOf crm:E22_Human_Made_Object .

myont:Artist a owl:Class ;
    rdfs:label "Artist" ;
    rdfs:subClassOf crm:E21_Person .

myont:Theme a owl:Class ;
    rdfs:label "Theme" .

crm:E22_Human_Made_Object a owl:Class ;
    rdfs:label "Human Made Object" .

myont:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:equivalentClass schema:Painting .

