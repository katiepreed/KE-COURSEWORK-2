@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix myont: <https://ontologeez/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

crm:P102_has_title a owl:DatatypeProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:name .

myont:City a owl:Class ;
    rdfs:label "City" ;
    rdfs:subClassOf crm:E53_Place ;
    owl:disjointWith myont:Country,
        myont:Region .

myont:EgyptianAnimalFigurine a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Figurine [ a owl:Restriction ;
                        owl:onProperty myont:hasTheme ;
                        owl:someValuesFrom myont:AnimalTheme ] [ a owl:Restriction ;
                        owl:hasValue "egyptian"^^xsd:string ;
                        owl:onProperty myont:hasCulture ] ) ] .

myont:MythologicalTheme a owl:Class ;
    rdfs:label "Mythological theme" ;
    rdfs:subClassOf myont:Theme .

myont:NaturalWorldTheme a owl:Class ;
    rdfs:subClassOf myont:Theme ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( myont:NatureTheme myont:AnimalTheme ) ] .

myont:NatureOilPainting a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Painting [ a owl:Restriction ;
                        owl:onProperty myont:hasTheme ;
                        owl:someValuesFrom myont:NatureTheme ] [ a owl:Restriction ;
                        owl:hasValue "oil"^^xsd:string ;
                        owl:onProperty myont:mediumDescription ] ) ] .

myont:Painter a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Artist [ a owl:Restriction ;
                        owl:onProperty myont:hasCreated ;
                        owl:someValuesFrom myont:Painting ] ) ] .

myont:ReligiousTheme a owl:Class ;
    rdfs:label "Religious theme" ;
    rdfs:subClassOf myont:Theme .

myont:Sculptor a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Artist [ a owl:Restriction ;
                        owl:onProperty myont:hasCreated ;
                        owl:someValuesFrom myont:Sculpture ] ) ] .

myont:Statue a owl:Class ;
    rdfs:label "Statue" ;
    rdfs:subClassOf myont:Sculpture ;
    owl:disjointWith myont:Figurine .

myont:ThreeDimensionalWork a owl:Class ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( myont:Sculpture myont:Vase myont:Ceramic myont:Jewellery ) ] .

myont:bornOn a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "born in" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:gYear .

myont:createdBy a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "created by artist" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Artist ;
    rdfs:subPropertyOf crm:P108i_was_produced_by,
        schema:creator ;
    owl:inverseOf myont:hasCreated .

myont:diedOn a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "died in" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:gYear .

myont:displayedBy a owl:ObjectProperty ;
    rdfs:label "displayed by museum" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Museum ;
    owl:inverseOf myont:displays .

myont:endDate a owl:DatatypeProperty ;
    rdfs:label "artwork finished in" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:gYear .

myont:hasDepartment a owl:ObjectProperty ;
    rdfs:label "has department" ;
    rdfs:domain myont:Museum ;
    rdfs:range myont:Department ;
    owl:inverseOf myont:isDepartmentOf .

myont:hasDepartmentId a owl:DatatypeProperty ;
    rdfs:label "department id" ;
    rdfs:domain myont:Department ;
    rdfs:range xsd:integer .

myont:hasNationality a owl:DatatypeProperty ;
    rdfs:label "nationality" ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:string .

myont:hasObjectId a owl:DatatypeProperty ;
    rdfs:label "object id" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:integer .

myont:hasPeriod a owl:DatatypeProperty ;
    rdfs:label "period" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:startDate a owl:DatatypeProperty ;
    rdfs:label "started in" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:gYear .

schema:Person a owl:Class ;
    rdfs:label "Person" ;
    owl:equivalentClass crm:E21_Person .

schema:dateCreated a owl:DatatypeProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:gYear .

schema:displayLocation a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place ;
    owl:equivalentProperty crm:P55_has_current_location .

schema:locationCreated a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

crm:P108i_was_produced_by a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E39_Actor .

crm:P55_has_current_location a owl:ObjectProperty ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

myont:Country a owl:Class ;
    rdfs:label "Country" ;
    rdfs:subClassOf crm:E53_Place ;
    owl:disjointWith myont:Region .

myont:departmentDisplays a owl:ObjectProperty ;
    rdfs:label "department displays" ;
    rdfs:domain myont:Department ;
    rdfs:range crm:E22_Human_Made_Object ;
    owl:inverseOf myont:displayedInDepartment .

myont:displayedInDepartment a owl:ObjectProperty ;
    rdfs:label "displayed in department" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Department .

myont:displays a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "displays" ;
    rdfs:domain myont:Museum ;
    rdfs:range crm:E22_Human_Made_Object .

myont:hasCulture a owl:DatatypeProperty ;
    rdfs:label "culture" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:isDepartmentOf a owl:ObjectProperty ;
    rdfs:label "is department of" ;
    rdfs:domain myont:Department ;
    rdfs:range myont:Museum .

myont:isThemeOf a owl:ObjectProperty ;
    rdfs:label "is theme of" ;
    rdfs:domain myont:Theme ;
    rdfs:range crm:E22_Human_Made_Object .

myont:mediumDescription a owl:DatatypeProperty ;
    rdfs:label "Labeled Medium" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

schema:Museum a owl:Class ;
    rdfs:label "Museum" .

schema:Painting a owl:Class ;
    rdfs:label "Painting" .

schema:Sculpture a owl:Class ;
    rdfs:label "Sculpture" .

schema:creator a owl:ObjectProperty .

schema:name a owl:DatatypeProperty ;
    rdfs:range xsd:string .

crm:E39_Actor a owl:Class ;
    rdfs:label "Actor" .

myont:AnimalTheme a owl:Class ;
    rdfs:label "Animal theme" ;
    rdfs:subClassOf myont:Theme .

myont:Ceramic a owl:Class ;
    rdfs:label "Ceramic" ;
    rdfs:subClassOf crm:E22_Human_Made_Object .

myont:Figurine a owl:Class ;
    rdfs:label "Figurine" ;
    rdfs:subClassOf myont:Sculpture .

myont:NatureTheme a owl:Class ;
    rdfs:label "Nature theme" ;
    rdfs:subClassOf myont:Theme .

myont:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Ceramic,
        myont:Jewellery,
        myont:Scroll,
        myont:Sculpture,
        myont:Vase ;
    owl:equivalentClass schema:Painting .

myont:Region a owl:Class ;
    rdfs:label "Region" ;
    rdfs:subClassOf crm:E53_Place .

myont:Vase a owl:Class ;
    rdfs:label "Vase" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Jewellery,
        myont:Scroll .

myont:hasTheme a owl:ObjectProperty ;
    rdfs:label "Theme" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Theme ;
    owl:inverseOf myont:isThemeOf .

myont:Artist a owl:Class ;
    rdfs:label "Artist" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty myont:hasCreated ],
        crm:E21_Person .

myont:Museum a owl:Class ;
    rdfs:label "Museum" ;
    owl:equivalentClass schema:Museum .

myont:Scroll a owl:Class ;
    rdfs:label "Scroll" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Jewellery .

myont:hasCreated a owl:ObjectProperty ;
    rdfs:label "has created" ;
    rdfs:domain myont:Artist ;
    rdfs:range crm:E22_Human_Made_Object .

crm:E21_Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf crm:E39_Actor .

myont:Department a owl:Class ;
    rdfs:label "Department" .

myont:Jewellery a owl:Class ;
    rdfs:label "Jewellery" ;
    rdfs:subClassOf crm:E22_Human_Made_Object .

myont:Sculpture a owl:Class ;
    rdfs:label "Sculpture" ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Jewellery,
        myont:Scroll ;
    owl:equivalentClass schema:Sculpture .

crm:E53_Place a owl:Class ;
    rdfs:label "Place" .

myont:Theme a owl:Class ;
    rdfs:label "Theme" .

crm:E22_Human_Made_Object a owl:Class ;
    rdfs:label "Human Made Object" .

[] a owl:Restriction ;
    owl:allValuesFrom myont:Scroll ;
    owl:onProperty myont:departmentDisplays .

