myont:NaturalWorldTheme a owl:Class ;
    rdfs:label "Natural world theme" ;
    rdfs:comment "A theme defined as either a nature theme or an animal theme." ;
    rdfs:subClassOf myont:Theme ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( myont:NatureTheme myont:AnimalTheme ) ] .

myont:NatureOilPainting a owl:Class ;
    rdfs:label "Nature oil painting" ;
    rdfs:comment "A painting defined as having a nature theme and the medium description 'oil on canvas'." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Painting [ a owl:Restriction ;
                        owl:onProperty myont:hasTheme ;
                        owl:someValuesFrom myont:NatureTheme ] [ a owl:Restriction ;
                        owl:hasValue "oil on canvas" ;
                        owl:onProperty myont:mediumDescription ] ) ] .

