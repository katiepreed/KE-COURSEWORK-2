myont:ThreeDimensionalWork a owl:Class ;
    rdfs:label "Three-dimensional human-made object" ;
    rdfs:comment "A human-made object defined as being either a sculpture, vase, ceramic, or jewellery item." ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( myont:Sculpture myont:Vase myont:Ceramic myont:Jewellery ) ] .

