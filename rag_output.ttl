myont:ChineseAnimalFigurine a owl:Class ;
    rdfs:label "Chinese animal figurine" ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( myont:Figurine [ a owl:Restriction ;
                        owl:onProperty myont:hasTheme ;
                        owl:someValuesFrom myont:AnimalTheme ] [ a owl:Restriction ;
                        owl:hasValue "china" ;
                        owl:onProperty myont:hasCulture ] ) ] .

