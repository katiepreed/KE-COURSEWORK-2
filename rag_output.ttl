myont:associatedWithMovement a owl:ObjectProperty ;
    rdfs:label "associated with movement" ;
    rdfs:domain myont:Artist ;
    rdfs:range myont:ArtisticMovement .

myont:bornOn a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "born in" ;
    rdfs:comment "The year in which a person was born." ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:integer .

myont:createdBy a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "created by artist" ;
    rdfs:comment "Relates a human-made object to the artist who created it." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Artist ;
    rdfs:subPropertyOf crm:P108i_was_produced_by,
        schema:creator ;
    owl:inverseOf myont:hasCreated .

myont:departmentDisplays a owl:ObjectProperty ;
    rdfs:label "department displays" ;
    rdfs:comment "Relates a museum department to the human-made objects it displays." ;
    rdfs:domain myont:Department ;
    rdfs:range crm:E22_Human_Made_Object ;
    owl:inverseOf myont:displayedInDepartment .

myont:diedOn a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "died in" ;
    rdfs:comment "The year in which a person died." ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:integer .

myont:displayedBy a owl:ObjectProperty ;
    rdfs:label "displayed by museum" ;
    rdfs:comment "Relates a human-made object to the museum that displays it." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Museum ;
    owl:inverseOf myont:displays .

myont:endDate a owl:DatatypeProperty ;
    rdfs:label "artwork finished in" ;
    rdfs:comment "The year in which the creation of a human-made object was completed." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:integer .

myont:hasDepartment a owl:ObjectProperty ;
    rdfs:label "has department" ;
    rdfs:comment "Relates a museum to a department that is part of it." ;
    rdfs:domain myont:Museum ;
    rdfs:range myont:Department ;
    owl:inverseOf myont:isDepartmentOf .

myont:hasDepartmentId a owl:DatatypeProperty ;
    rdfs:label "department id" ;
    rdfs:comment "An identifier assigned to a department within a museum." ;
    rdfs:domain myont:Department ;
    rdfs:range xsd:integer .

myont:hasGender a owl:DatatypeProperty ;
    rdfs:label "has gender" ;
    rdfs:comment "The gender of an artist." ;
    rdfs:domain myont:Artist ;
    rdfs:range xsd:string .

myont:hasNationality a owl:DatatypeProperty ;
    rdfs:label "nationality" ;
    rdfs:comment "A textual value describing the nationality of a person." ;
    rdfs:domain crm:E21_Person ;
    rdfs:range xsd:string .

myont:hasObjectId a owl:DatatypeProperty ;
    rdfs:label "object id" ;
    rdfs:comment "An identifier assigned to a human-made object within a museum collection." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:integer .

myont:hasPeriod a owl:DatatypeProperty ;
    rdfs:label "period" ;
    rdfs:comment "A textual value describing the historical or artistic period associated with a human-made object." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

myont:hasPrimaryMedium a owl:ObjectProperty ;
    rdfs:label "has medium" ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range myont:Medium .

myont:locatedIn a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "located in" ;
    rdfs:comment "A place located inside a larger place. Used for museum -> city, city -> country, and country ->region." ;
    rdfs:range crm:E53_Place .

myont:ragGenerated a owl:AnnotationProperty ;
    rdfs:label "RAG generated" ;
    rdfs:comment "True if this triple was generated by the RAG system rather than from the structured data pipeline." .

myont:startDate a owl:DatatypeProperty ;
    rdfs:label "started in" ;
    rdfs:comment "The year in which the creation of a human-made object began." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:integer .

schema:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human individual." ;
    owl:equivalentClass crm:E21_Person .

schema:dateCreated a owl:DatatypeProperty ;
    rdfs:label "date created" ;
    rdfs:comment "The year in which a human-made object was created." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range xsd:string .

schema:displayLocation a owl:ObjectProperty ;
    rdfs:label "display location" ;
    rdfs:comment "The place where a human-made object is currently displayed." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place ;
    owl:equivalentProperty crm:P55_has_current_location .

schema:locationCreated a owl:ObjectProperty ;
    rdfs:label "location created" ;
    rdfs:comment "The place where a human-made object was originally created." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

crm:P108i_was_produced_by a owl:ObjectProperty ;
    rdfs:label "was produced by" ;
    rdfs:comment "Relates a human-made object to the actor who produced or created it." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E39_Actor .

crm:P55_has_current_location a owl:ObjectProperty ;
    rdfs:label "has current location" ;
    rdfs:comment "Relates a human-made object to the place where it is currently located." ;
    rdfs:domain crm:E22_Human_Made_Object ;
    rdfs:range crm:E53_Place .

