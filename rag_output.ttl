    rdfs:subClassOf crm:E39_Actor .

myont:ArtisticMovement a owl:Class ;
    rdfs:label "Artistic Movement" ;
    rdfs:comment "A named artistic movement, school, or style (e.g. Impressionism)." .

myont:Medium a owl:Class ;
    rdfs:label "Medium" ;
    rdfs:comment "The primary material or technique used to create an artwork." .

myont:MythologicalTheme_instance a myont:MythologicalTheme ;
    rdfs:label "Mythological" .

myont:Sculpture a owl:Class ;
    rdfs:label "Sculpture" ;
    rdfs:comment "A sculpture in the custom ontology, modeled as a human-made object and aligned with schema.org Sculpture." ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Jewellery,
        myont:Scroll ;
    owl:equivalentClass schema:Sculpture .

myont:Ceramic a owl:Class,
        myont:Medium ;
    rdfs:label "Ceramic" ;
    rdfs:comment "A human-made object made from clay or similar material hardened by heat." ;
    rdfs:subClassOf crm:E22_Human_Made_Object .

myont:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:comment "A painting in the custom ontology, modeled as a human-made object and aligned with schema.org Painting." ;
    rdfs:subClassOf crm:E22_Human_Made_Object ;
    owl:disjointWith myont:Ceramic,
        myont:Jewellery,
        myont:Scroll,
        myont:Sculpture,
        myont:Vase ;
    owl:equivalentClass schema:Painting .

myont:Artist a owl:Class ;
    rdfs:label "Artist" ;
    rdfs:comment "A person who creates artworks such as paintings, sculptures, or other museum objects." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty myont:hasCreated ],
        crm:E21_Person .

